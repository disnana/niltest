---
import type { Page } from "@/content/pages";
import DocsLayout from "@/layouts/DocsLayout.astro";
import { t } from "@/locales";
import { docUrl } from "@/lib/urls";
import { pages } from "@/content/pages";
import CodeBlock from "@/components/CodeBlock.astro";
import InstallCommand from "@/components/InstallCommand.astro";

type Props = { page: Page; locale: string };
const { page, locale } = Astro.props;
const index = pages.findIndex((item) => item.slug === page.slug);
const previous = index > 0 ? pages[index - 1] : undefined;
const next = index < pages.length - 1 ? pages[index + 1] : undefined;
const isHome = page.slug === "";
const inlineCode = (value: string) => value.replace(/`([^`]+)`/g, "<code>$1</code>");
---

<DocsLayout locale={locale} slug={page.slug} title={t(locale, page.title)} description={t(locale, page.lead)}>
  <article class:list={["doc-article", isHome && "home-article"]}>
    <div class="doc-layout">
      <div class="doc-main">
        <header class="page-header">
          <p class="eyebrow">{t(locale, page.eyebrow)}</p>
          <h1>{t(locale, page.title)}</h1>
          <p class="page-lead">{t(locale, page.lead)}</p>
          {isHome && (
            <div class="hero-actions">
              <a class="primary-button" href={docUrl(locale, "getting-started")}>{t(locale, "ui.start")}</a>
              <div class="quick-install"><code tabindex="0">pip install niltest</code><button type="button" data-copy-install aria-live="polite">{locale === "ja" ? "コピー" : "Copy"}</button></div>
            </div>
          )}
          {isHome && (
            <div class="hero-proof" aria-label="Project properties">
              <span><strong>0</strong> runtime deps</span>
              <span><strong>3</strong> modes</span>
              <span><strong>2+</strong> languages</span>
            </div>
          )}
        </header>

        <div class="article-body">
          {page.sections.map((section) => (
            <section id={section.id}>
              <h2><a href={`#${section.id}`}>{t(locale, section.title)}</a></h2>
              {section.paragraphs?.map((key) => <p set:html={inlineCode(t(locale, key))} />)}
              {section.bullets && <ul>{section.bullets.map((key) => <li set:html={inlineCode(t(locale, key))} />)}</ul>}
              {page.slug === "getting-started" && section.id === "install"
                ? <InstallCommand locale={locale} />
                : section.code && <CodeBlock code={section.code} locale={locale} />}
              {section.note && <aside class="note"><span aria-hidden="true">i</span><p set:html={inlineCode(t(locale, section.note))} /></aside>}
            </section>
          ))}
        </div>
      </div>
      <aside class="toc">
        <p>{t(locale, "ui.onThisPage")}</p>
        {page.sections.map((section) => <a href={`#${section.id}`}>{t(locale, section.title)}</a>)}
        <a class="edit-link" href={`https://github.com/disnana/niltest/tree/main/docs-site/src/locales/catalogs/${locale}.ts`}>{t(locale, "ui.edit")}</a>
      </aside>
    </div>

    <nav class="pager" aria-label="Pagination">
      {previous ? <a href={docUrl(locale, previous.slug)}><span>{t(locale, "ui.previous")}</span><strong>{t(locale, previous.nav)}</strong></a> : <span />}
      {next && <a class="next" href={docUrl(locale, next.slug)}><span>{t(locale, "ui.next")}</span><strong>{t(locale, next.nav)}</strong></a>}
    </nav>
  </article>
</DocsLayout>

<script>
  document.querySelector("[data-copy-install]")?.addEventListener("click", async (event) => {
    const button = event.currentTarget;
    if (!(button instanceof HTMLButtonElement)) return;
    const code = button.closest(".quick-install")?.querySelector("code")?.textContent ?? "pip install niltest";
    await navigator.clipboard.writeText(code);
    const original = button.textContent;
    button.textContent = document.documentElement.lang === "ja" ? "コピーしました ✓" : "Copied ✓";
    button.classList.add("copied");
    setTimeout(() => {
      button.classList.remove("copied");
      button.textContent = original;
    }, 2200);
  });
</script>
