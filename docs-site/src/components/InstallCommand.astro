---
const { locale = "ja" } = Astro.props;
const ja = locale === "ja";
---

<div class="command-picker" data-command-picker data-locale={locale}>
  <button class="auto-command" type="button" data-auto-command>{ja ? "わからない場合はこちら（自動選択）" : "Not sure? Choose automatically"}</button>
  <div class="picker-group">
    <span class="picker-label">{ja ? "OS" : "OS"}</span>
    <div class="picker-tabs" role="tablist" aria-label={ja ? "OSを選択" : "Select operating system"}>
      <button class="active" type="button" data-os="windows">Windows</button>
      <button type="button" data-os="macos">macOS</button>
      <button type="button" data-os="ubuntu">Ubuntu</button>
    </div>
  </div>
  <div class="picker-group">
    <span class="picker-label">{ja ? "環境" : "Environment"}</span>
    <div class="picker-tabs environment-tabs" role="tablist" aria-label={ja ? "Python環境を選択" : "Select Python environment"}>
      <button class="active" type="button" data-env="venv">{ja ? "仮想環境を有効化済み" : "Virtual environment active"}</button>
      <button type="button" data-env="path">{ja ? "PATH設定済み" : "Python on PATH"}</button>
      <button type="button" data-env="no-path">{ja ? "PATH未設定" : "Not on PATH"}</button>
    </div>
  </div>
  <div class="picked-command">
    <code data-command tabindex="0">pip install niltest</code>
    <button type="button" data-copy-command aria-live="polite">{ja ? "コピー" : "Copy"}</button>
  </div>
  <p class="picker-hint" data-command-hint>{ja ? "有効化中の仮想環境へインストールします。" : "Installs into the active virtual environment."}</p>
</div>

<script>
  const commands = {
    windows: {
      venv: ["pip install niltest", "有効化中の仮想環境へインストールします。", "Installs into the active virtual environment."],
      path: ["python -m pip install niltest", "PATH上のPythonを明示してインストールします。", "Uses the Python interpreter available on PATH."],
      "no-path": ["py -m pip install niltest", "Windows Python Launcherを使用します。利用できない場合はpython.exeの絶対パスを指定してください。", "Uses the Windows Python Launcher. Otherwise, provide the absolute path to python.exe."],
    },
    macos: {
      venv: ["pip install niltest", "有効化中の仮想環境へインストールします。", "Installs into the active virtual environment."],
      path: ["python3 -m pip install niltest", "PATH上のPython 3を明示してインストールします。", "Uses Python 3 available on PATH."],
      "no-path": ["/path/to/python3 -m pip install niltest", "python3の実際の絶対パスへ置き換えてください。", "Replace /path/to/python3 with the interpreter's absolute path."],
    },
    ubuntu: {
      venv: ["pip install niltest", "有効化中の仮想環境へインストールします。", "Installs into the active virtual environment."],
      path: ["python3 -m pip install niltest", "PATH上のPython 3を明示してインストールします。", "Uses Python 3 available on PATH."],
      "no-path": ["/path/to/python3 -m pip install niltest", "python3の実際の絶対パスへ置き換えてください。", "Replace /path/to/python3 with the interpreter's absolute path."],
    },
  } as const;

  document.querySelectorAll<HTMLElement>("[data-command-picker]").forEach((picker) => {
    let os: keyof typeof commands = "windows";
    let environment: keyof (typeof commands)["windows"] = "venv";
    const command = picker.querySelector<HTMLElement>("[data-command]");
    const hint = picker.querySelector<HTMLElement>("[data-command-hint]");
    const copy = picker.querySelector<HTMLButtonElement>("[data-copy-command]");
    const automatic = picker.querySelector<HTMLButtonElement>("[data-auto-command]");
    const isJa = picker.dataset.locale === "ja";
    const update = () => {
      const selected = commands[os][environment];
      if (command) command.textContent = selected[0];
      if (hint) hint.textContent = selected[isJa ? 1 : 2];
    };
    picker.querySelectorAll<HTMLButtonElement>("[data-os]").forEach((button) => button.addEventListener("click", () => {
      os = button.dataset.os as keyof typeof commands;
      picker.querySelectorAll("[data-os]").forEach((item) => item.classList.toggle("active", item === button));
      update();
    }));
    picker.querySelectorAll<HTMLButtonElement>("[data-env]").forEach((button) => button.addEventListener("click", () => {
      environment = button.dataset.env as keyof (typeof commands)["windows"];
      picker.querySelectorAll("[data-env]").forEach((item) => item.classList.toggle("active", item === button));
      update();
    }));
    copy?.addEventListener("click", async () => {
      await navigator.clipboard.writeText(command?.textContent ?? "");
      copy.textContent = isJa ? "コピーしました ✓" : "Copied ✓";
      copy.classList.add("copied");
      setTimeout(() => { copy.textContent = isJa ? "コピー" : "Copy"; copy.classList.remove("copied"); }, 2200);
    });
    automatic?.addEventListener("click", async () => {
      const original = isJa ? "わからない場合はこちら（自動選択）" : "Not sure? Choose automatically";
      const platform = navigator.userAgent.toLowerCase();
      os = platform.includes("win") ? "windows" : platform.includes("mac") ? "macos" : "ubuntu";
      environment = "path";
      picker.querySelectorAll<HTMLButtonElement>("[data-os]").forEach((item) => item.classList.toggle("active", item.dataset.os === os));
      picker.querySelectorAll<HTMLButtonElement>("[data-env]").forEach((item) => item.classList.toggle("active", item.dataset.env === environment));
      update();
      try {
        await navigator.clipboard.writeText(command?.textContent ?? "");
        automatic.textContent = isJa ? "推奨コマンドをコピーしました ✓" : "Recommended command copied ✓";
        automatic.classList.add("copied");
      } catch {
        automatic.textContent = isJa ? "選択しました。コピーボタンを使用してください" : "Selected. Use the copy button.";
        automatic.classList.add("copy-failed");
      }
      setTimeout(() => {
        automatic.textContent = original;
        automatic.classList.remove("copied", "copy-failed");
      }, 2400);
    });
  });
</script>
