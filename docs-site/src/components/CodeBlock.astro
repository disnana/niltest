---
import { codeToHtml } from "shiki";
import { t } from "@/locales";

type Props = { code: string; locale: string };
const { code, locale } = Astro.props;
const first = code.trimStart().split("\n", 1)[0] ?? "";
const lang = /^(pip |python |niltest |NILTEST_MODE=|\$env:|# (macOS|Windows))/.test(first) ? "shellscript" : "python";
const highlighted = await codeToHtml(code, {
  lang,
  themes: { light: "github-light", dark: "github-dark" },
  defaultColor: false,
});
---

<div class="code-block">
  <div class="code-head">
    <span>{lang === "python" ? "python" : "shell"}</span>
    <button type="button" data-copy data-copied={`${t(locale, "ui.copied")} ✓`} aria-live="polite">{t(locale, "ui.copy")}</button>
  </div>
  <div class="highlighted-code" set:html={highlighted} />
</div>
